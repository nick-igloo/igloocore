                  {
                    "leftValue": "={{ $json.body.action }}",
                    "rightValue": "draft_offer",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "draft_offer"
            }
