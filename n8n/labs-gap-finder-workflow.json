        },
        "options": {}
      },
      "id": "switch-action",
      "name": "Route by action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        180,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: 'claude-sonnet-4-6',\n  max_tokens: 600,\n  messages: [{\n    role: 'user',\n    content: 'You write promotional copy for Igloo, a short-term rental management company in the Cairngorms, Scotland. A property has an unbooked gap to fill. Write three pieces in warm, plain UK English (no hyperbole, no exclamation-mark overload): 1) an ad headline under 12 words, 2) a social post under 60 words with the dates, 3) a two-sentence email snippet for past guests. Mention the property name and dates naturally. Respond ONLY with JSON: {\"headline\": \"...\", \"social\": \"...\", \"email\": \"...\"}. No markdown fences.\\n\\nGap: ' + JSON.stringify($json.body.gap)\n  }]\n}) }}",
        "options": {}
      },
      "id": "claude-offer",
      "name": "Claude: draft offer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        420,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_ANTHROPIC_HEADER_CRED",
          "name": "Anthropic x-api-key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = ($json.content || []).filter(b => b.type === 'text').map(b => b.text).join('').trim();\nconst clean = raw.replace(/```json|```/g, '').trim();\nlet parsed;\ntry { parsed = JSON.parse(clean); } catch (e) { throw new Error('Claude did not return valid JSON: ' + clean.slice(0, 200)); }\nreturn [{ json: parsed }];"
      },
      "id": "extract-offer",
      "name": "Extract offer",
      "type": "n8n-nodes-base.code",
